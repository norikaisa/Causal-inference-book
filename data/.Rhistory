library(grf)
data <- read.csv("a_impute_CF.csv")
data$outcome <- ifelse(data$Y == "Yes",1,0)
data$W<- ifelse(data$T == "Endoscopy",1,0)
model <- glm(outcome ~ W + K + Age+ Duration + GH_base + IGF_base + Tumor_base, data= data, family = "binomial")
data$W <- 0
predict <- predict(model, newdata = data, type ="response")
plot(predict, ITE)
data <- read.csv("a_impute_CF.csv")
Y <- ifelse(data$Y == "Yes",1,0)
W <- ifelse(data$T == "Endoscopy",1,0)
X <- data.frame(data$K,data$Age,data$Duration,data$GH_base,data$IGF_base,data$Tumor_base)
c.forest <- causal_forest(X, Y, W)
data$ITE = predict(c.forest)$predictions
forest.Y <- regression_forest(X, Y)
Y.hat <- predict(forest.Y)$predictions
forest.W <- regression_forest(X, W)
W.hat <- predict(forest.W)$predictions
c.forest <- causal_forest(X, Y, W, Y.hat, W.hat)
tau.hat <- predict(c.forest)$predictions
mu.hat.0 <- Y.hat - W.hat * tau.hat
mu.hat.1 <- Y.hat + (1 - W.hat) * tau.hat
plot(mu.hat.0, ITE)
plot(data$Tumor_base, data$ITE)
plot(data$k, data$ITE)
